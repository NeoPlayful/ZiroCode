generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String?
  role         Role     @default(USER)
  referralCode String   @unique
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apiKeys       ApiKey[]
  subscriptions Subscription[]
  transactions  Transaction[]
  usageLogs     ApiUsageLog[]
  referrals     Referral[]           @relation("referrer")
  referred      Referral?            @relation("referred")
  withdrawals   WithdrawalRequest[]
  tickets       Ticket[]
  ticketReplies TicketReply[]
  readAnnouncements AnnouncementRead[]
  notifications Notification[]
  notificationPreference NotificationPreference?
  webhooks WebhookEndpoint[]

  @@index([email])
  @@index([referralCode])
}

enum Role {
  USER
  ADMIN
}

// API 密钥表
model ApiKey {
  id            String    @id @default(cuid())
  userId        String
  key           String    @unique
  name          String
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  ipWhitelist   String[]  @default([])
  rateLimit     Int?      @default(60)
  allowedModels String[]  @default([])
  maxTokens     Int?      @default(4096)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs ApiUsageLog[]

  @@index([userId])
  @@index([key])
}

// 订阅表
model Subscription {
  id               String           @id @default(cuid())
  userId           String
  type             SubscriptionType
  quotaTotal       BigInt
  quotaUsed        BigInt           @default(0)
  quotaMonthly     BigInt?
  quotaMonthlyUsed BigInt           @default(0)
  startsAt         DateTime
  expiresAt        DateTime?
  isActive         Boolean          @default(true)
  lastResetAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([isActive])
}

enum SubscriptionType {
  PAY_AS_YOU_GO
  MONTHLY
  PERMANENT
}

// 兑换码表
model RedeemCode {
  id          String    @id @default(cuid())
  code        String    @unique
  quotaAmount BigInt
  type        SubscriptionType
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  transactions Transaction[]

  @@index([code])
  @@index([isActive])
}

// 交易记录表
model Transaction {
  id             String             @id @default(cuid())
  userId         String
  type           TransactionType
  amount         Decimal            @db.Decimal(10, 2)
  quotaAmount    BigInt?
  description    String
  subscriptionId String?
  redeemCodeId   String?
  status         TransactionStatus  @default(SUCCEEDED)
  createdAt      DateTime           @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  redeemCode   RedeemCode?   @relation(fields: [redeemCodeId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

enum TransactionType {
  REDEEM
  ADMIN_ADJUST
  REFERRAL_REWARD
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// 推荐关系表
model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String   @unique
  tier          Int      @default(1)
  totalReward   BigInt   @default(0)
  claimedReward BigInt   @default(0)
  isFraud       Boolean  @default(false)
  createdAt     DateTime @default(now())

  referrer  User                   @relation("referrer", fields: [referrerId], references: [id])
  referred  User                   @relation("referred", fields: [referredId], references: [id])
  fraudLogs ReferralFraudLog[]

  @@index([referrerId])
}

// 推荐作弊记录表
model ReferralFraudLog {
  id          String      @id @default(cuid())
  referralId  String
  fraudType   FraudType
  evidence    Json
  status      FraudStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

enum FraudType {
  SAME_IP
  RAPID_REGISTRATION
  SUSPICIOUS_PATTERN
  DEVICE_DUPLICATE
}

enum FraudStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

// 提现申请表
model WithdrawalRequest {
  id          String            @id @default(cuid())
  userId      String
  amount      Decimal           @db.Decimal(10, 2)
  status      WithdrawalStatus  @default(PENDING)
  createdAt   DateTime          @default(now())
  processedAt DateTime?
  remark      String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

// 工单分类表
model TicketCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#3B82F6")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tickets   Ticket[]
  templates TicketTemplate[]
}

// 工单模板表
model TicketTemplate {
  id         String   @id @default(cuid())
  name       String
  title      String
  content    String
  categoryId String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  category TicketCategory? @relation(fields: [categoryId], references: [id])
}

// 工单表
model Ticket {
  id          String         @id @default(cuid())
  userId      String
  title       String
  content     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(NORMAL)
  categoryId  String?
  slaDeadline DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  category TicketCategory? @relation(fields: [categoryId], references: [id])
  replies  TicketReply[]

  @@index([userId, status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// 公告表
model Announcement {
  id        String             @id @default(cuid())
  title     String
  content   String
  priority  Int                @default(0)
  isPinned  Boolean            @default(false)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  readBy AnnouncementRead[]
}

model AnnouncementRead {
  id             String @id @default(cuid())
  userId         String
  announcementId String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, announcementId])
}

// API 使用日志表
model ApiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  apiKeyId     String
  model        String
  tokensUsed   Int
  quotaUsed    BigInt
  statusCode   Int
  error        String?
  requestTime  DateTime @default(now())
  responseTime DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([userId, requestTime])
  @@index([apiKeyId])
  @@index([model, requestTime])
  @@index([requestTime])
}

// 订阅套餐定价表
model SubscriptionPlan {
  id           String           @id @default(cuid())
  name         String           @unique
  type         SubscriptionType
  price        Decimal          @db.Decimal(10, 2)
  quotaAmount  BigInt
  durationDays Int?
  stripePriceId String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
}

// 模型渠道表
model ModelChannel {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  baseUrl     String
  apiKey      String
  models      String[]
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isActive, priority])
}

// 通知表
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum NotificationType {
  QUOTA_LOW
  QUOTA_EXHAUSTED
  SUBSCRIPTION_EXPIRING
  PAYMENT_SUCCESS
  TICKET_REPLY
  ANNOUNCEMENT
  REFERRAL_REWARD
  WEBHOOK_FAILED
}

// 通知偏好表
model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  quotaLow             Boolean  @default(true)
  quotaExhausted       Boolean  @default(true)
  subscriptionExpiring Boolean  @default(true)
  marketing            Boolean  @default(false)
  emailDigest          Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Webhook 端点表
model WebhookEndpoint {
  id            String        @id @default(cuid())
  userId        String
  name          String
  url           String
  secret        String
  events        WebhookEvent[]
  isActive      Boolean       @default(true)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
}

model WebhookLog {
  id           String        @id @default(cuid())
  endpointId   String
  event        WebhookEvent
  statusCode   Int?
  responseBody String?
  success      Boolean
  durationMs   Int?
  createdAt    DateTime      @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([success, createdAt])
}

enum WebhookEvent {
  QUOTA_LOW
  QUOTA_EXHAUSTED
  PAYMENT_SUCCESS
  API_CALL_COMPLETED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
}

// 审计日志表
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  detail     Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
}

// 系统配置表
model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
